{
  "name": "airmove-analyzer",
  "private": true,
  "version": "0.1.0",
  "description": "Gimpo Radar Site flight inspection track analysis system — ASTERIX CAT048 parser, GPU-rendered track map, signal loss detection, LOS profiling, and PDF report generation",
  "author": "Gimpo Radar Site Flight Inspection Team",
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\""
  },
  "dependencies": {
    "@deck.gl/core": "^9.2.11",
    "@deck.gl/layers": "^9.2.11",
    "@deck.gl/mapbox": "^9.2.11",
    "@deck.gl/react": "^9.2.11",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-fs": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "date-fns": "^4.1.0",
    "html2canvas-pro": "^2.0.2",
    "jspdf": "^2.5.2",
    "jspdf-autotable": "^5.0.7",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.468.0",
    "maplibre-gl": "^5.20.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-leaflet": "^5.0.0",
    "react-map-gl": "^8.1.0",
    "react-router-dom": "^7.1.0",
    "zustand": "^5.0.0"
